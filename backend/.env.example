# Backend ortam değişkenleri — GERÇEK DEĞER KOYMA, bu dosya örnektir.
# Kopyala: cp backend/.env.example backend/.env  (.env git-ignore'dadır)

# ── Veritabanı ──────────────────────────────────────────
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=metropolbusiness;Username=metropol;Password=CHANGE_ME

# ── Redis ───────────────────────────────────────────────
Redis__Configuration=localhost:6379
# false: IDistributedCache in-memory çalışır (tek instance geliştirme/test).
# true: OTP/refresh/rate-limit anahtarları Redis'te tutulur (çoklu instance/üretim için zorunlu).
Redis__Enabled=false

# ── Auth / OTP ──────────────────────────────────────────
Auth__OtpTtlSeconds=180
Auth__ResendSeconds=60
Auth__MaxAttempts=3
# DevFixedOtp YALNIZCA geliştirme içindir (sabit OTP kodu); üretimde BOŞ bırakılır.
Auth__DevFixedOtp=

# ── JWT ─────────────────────────────────────────────────
Jwt__Issuer=metropolbusiness
Jwt__Audience=metropolbusiness-clients
Jwt__SigningKey=CHANGE_ME_min_32_chars_random_secret_key
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# ── Metropol entegrasyonu (SIR — yalnızca backend) ─────
Metropol__AuthBaseUrl=https://testauth.metropolodeme.com
Metropol__ApiBaseUrl=https://testapi.metropolcard.com
Metropol__AccessKey=CHANGE_ME
Metropol__AesKey=CHANGE_ME
Metropol__ConsumerId=CHANGE_ME
Metropol__ConsumerName=CHANGE_ME

# ── Gemini (SIR — yalnızca backend) ────────────────────
Gemini__ApiKey=CHANGE_ME
Gemini__Model=gemini-2.0-flash

# ── Uygulama ────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
