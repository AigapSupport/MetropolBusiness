# ============================================================
# MetropolBusiness — production env (aigap-deploy-template deseni)
# Kopyala: cp .env.production.example .env.production && chmod 600 .env.production
# ASLA git'e commit ETME (.gitignore .env.* zaten engelliyor).
#
# Güçlü secret üret:  openssl rand -hex 24  (DB)  /  openssl rand -hex 48  (JWT)
# ============================================================

# --- Git (deploy.sh kodu buradan çeker; private repo için token'ı URL'e göm) ---
GIT_REPO_URL=https://github.com/AigapSupport/CHANGE_ME.git
GIT_BRANCH=main

# --- Compose ---
COMPOSE_FILE=docker-compose.prod.yml
IMAGE_TAG=v1.0.0

# --- Traefik (paylaşılan reverse proxy ağı; bu VPS'te SABİT) ---
TRAEFIK_NETWORK=aigap-prod_aigap-net

# --- Domain'ler (scripts/traefik-route.sh için; 3 route) ---
#   api    → metropolbusiness-app:8080   (mobil + SignalR /hubs/chat)
#   panel  → metropolbusiness-panel:80   (firma yönetim paneli)
#   admin  → metropolbusiness-admin:80   (platform paneli)
DOMAIN=CHANGE_ME.com
API_DOMAIN=api.CHANGE_ME.com
PANEL_DOMAIN=panel.CHANGE_ME.com
ADMIN_DOMAIN=yonetim.CHANGE_ME.com

# --- Health check (deploy.sh container içinden wget ile bakar) ---
HEALTHCHECK_SERVICE=app
HEALTHCHECK_PORT=8080
HEALTHCHECK_PATH=/health

# --- Veritabanı ---
DB_SERVICE=db
DB_USER=metropol
DB_PASSWORD=CHANGE_ME
DB_NAME=metropolbusiness

# --- Migration (deploy.sh up'tan önce çalıştırır; imaj migrate komutunu destekler) ---
MIGRATE_SERVICE=app
MIGRATE_CMD=dotnet MetropolBusiness.Api.dll migrate

# --- JWT (min 32 karakter; openssl rand -hex 48) ---
JWT_SIGNING_KEY=CHANGE_ME

# --- Metropol entegrasyonu (SIR — yalnızca backend) ---
# Test: testauth.metropolodeme.com / testapi.metropolcard.com — prod URL'leri Metropol verir.
METROPOL_AUTH_URL=https://testauth.metropolodeme.com
METROPOL_API_URL=https://testapi.metropolcard.com
METROPOL_ACCESS_KEY=CHANGE_ME
METROPOL_AES_KEY=CHANGE_ME
METROPOL_CONSUMER_ID=CHANGE_ME
METROPOL_CONSUMER_NAME=CHANGE_ME

# --- Gemini (AI sohbet asistanı) ---
GEMINI_API_KEY=CHANGE_ME
